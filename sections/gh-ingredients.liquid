<section class="gh-ingredients">
  <div class="gh-ingredients__inner">
    <div class="gh-ingredients__image-wrap gh-fade-scale">
      <img
        src="{{ 'Ingredient_List.png' | file_url }}"h
        alt="Overhead flat lay of 5 ceramic bowls with labeled raw ingredients: Turmeric Powder, Oat Flour, Dried Kojic Mushrooms, Orange Zest, Aloe Vera Gel. Soap bar centered below."
        class="gh-ingredients__image"
        width="600"
        height="600"
        loading="lazy"
      >
    </div>

    <div class="gh-ingredients__content">
      <div class="gh-section-header" style="text-align:left;">
        <span class="gh-section-eyebrow">What's Inside</span>
        <h2 class="gh-section-title">Five Ingredients.<br>One Powerful Glow.</h2>
      </div>

      <div class="gh-ingredient-card">
        <div class="gh-ingredient-number" aria-hidden="true">1</div>
        <div>
          <h3 class="gh-ingredient-name">Turmeric Root</h3>
          <p class="gh-ingredient-desc">Antioxidants and anti-inflammatory compounds revive skin, bring out natural radiance, and fade dark spots. The golden child of skincare superfoods.</p>
        </div>
      </div>

      <div class="gh-ingredient-card">
        <div class="gh-ingredient-number" aria-hidden="true">2</div>
        <div>
          <h3 class="gh-ingredient-name">Kojic Acid</h3>
          <p class="gh-ingredient-desc">Naturally derived from fungi during fermentation. Inhibits melanin production to brighten skin tone and reduce hyperpigmentation.</p>
        </div>
      </div>

      <div class="gh-ingredient-card">
        <div class="gh-ingredient-number" aria-hidden="true">3</div>
        <div>
          <h3 class="gh-ingredient-name">Alpha Arbutin</h3>
          <p class="gh-ingredient-desc">Extracted from bearberry plant. Works with kojic acid to prevent new dark spots while existing ones fade.</p>
        </div>
      </div>

      <div class="gh-ingredient-card">
        <div class="gh-ingredient-number" aria-hidden="true">4</div>
        <div>
          <h3 class="gh-ingredient-name">Oat Extract</h3>
          <p class="gh-ingredient-desc">Soothes, cleanses, moisturizes. Protects the skin barrier, reduces dryness and redness. Perfect for sensitive skin.</p>
        </div>
      </div>

      <div class="gh-ingredient-card">
        <div class="gh-ingredient-number" aria-hidden="true">5</div>
        <div>
          <h3 class="gh-ingredient-name">Vitamin C</h3>
          <p class="gh-ingredient-desc">Powerful antioxidant. Improves tone and texture, hydrates deeply, and reduces signs of aging — glow from within.</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "GH Ingredients",
  "tag": "section",
  "settings": [],
  "presets": [
    {
      "name": "GH Ingredients"
    }
  ]
}
{% endschema %}
