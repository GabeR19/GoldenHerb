<section class="gh-before-after">
  <div class="gh-before-after__inner">
    <div class="gh-before-after__image-wrap gh-fade-scale">
      <img
        src="{{ 'Before_and_After.png' | file_url }}"
        alt="Before and after results showing visibly brighter, more even skin tone after using Golden Herb Co. soap"
        class="gh-before-after__image"
        width="600"
        height="600"
        loading="lazy"
      >
    </div>

    <div class="gh-before-after__content">
      <div class="gh-section-header" style="text-align:left;">
        <span class="gh-section-eyebrow gh-fade-up">Proven Results</span>
        <h2 class="gh-section-title gh-fade-up gh-stagger-1">Real Transformations.<br>Real Confidence.</h2>
      </div>

      <div class="gh-before-after__stats">
        <div class="gh-stat gh-fade-up">
          <span class="gh-stat__number">93%</span>
          <span class="gh-stat__label">saw brighter skin in 4 weeks</span>
        </div>

        <div class="gh-stat gh-fade-up gh-stagger-1">
          <span class="gh-stat__number">87%</span>
          <span class="gh-stat__label">reduction in dark spots</span>
        </div>

        <div class="gh-stat gh-fade-up gh-stagger-2">
          <span class="gh-stat__number">4.9/5</span>
          <span class="gh-stat__label">average customer rating</span>
        </div>

        <div class="gh-stat gh-fade-up gh-stagger-3">
          <span class="gh-stat__number">10,000+</span>
          <span class="gh-stat__label">bars sold</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "GH Before & After",
  "tag": "section",
  "settings": [],
  "presets": [
    {
      "name": "GH Before & After"
    }
  ]
}
{% endschema %}
