<section class="gh-trust-bar">
  <div class="gh-trust-bar__inner">
    <p class="gh-trust-bar__counter gh-fade-up">
      Trusted By <span data-count="10000">0</span>+ Happy Customers
    </p>

    <div class="gh-trust-bar__badges">
      <div class="gh-trust-badge gh-fade-up">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M10 2l1.8 5.5H17l-4.6 3.4 1.8 5.5L10 13 5.8 16.4l1.8-5.5L3 7.5h5.2L10 2z" fill="currentColor"/>
        </svg>
        All Natural
      </div>
      <div class="gh-trust-badge gh-fade-up gh-stagger-1">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M10 3C6.1 3 3 6.1 3 10s3.1 7 7 7 7-3.1 7-7-3.1-7-7-7z" stroke="currentColor" stroke-width="1.5"/>
          <path d="M7 10.5l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Vegan
      </div>
      <div class="gh-trust-badge gh-fade-up gh-stagger-2">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M10 2c-2 3-6 4-6 8a6 6 0 0012 0c0-4-4-5-6-8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M10 10v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Handcrafted
      </div>
      <div class="gh-trust-badge gh-fade-up gh-stagger-3">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <rect x="3" y="3" width="14" height="14" rx="7" stroke="currentColor" stroke-width="1.5"/>
          <path d="M7 10h6M10 7v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Paraben &amp; Sulfate Free
      </div>
      <div class="gh-trust-badge gh-fade-up">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="8" r="3" stroke="currentColor" stroke-width="1.5"/>
          <path d="M4 18c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        For All Skin Types
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "GH Trust Bar",
  "tag": "section",
  "settings": [],
  "presets": [
    {
      "name": "GH Trust Bar"
    }
  ]
}
{% endschema %}
